{
  "name": "plumb-iq-remotion",
  "version": "1.0.0",
  "scripts": {
    "start": "npx remotion studio",
    "deploy:site": "npx remotion lambda sites create src/index.ts --site-name=plumb-iq",
    "deploy:lambda": "npx remotion lambda functions deploy --memory=3008 --disk=2048 --timeout=900 --retries=1 --region=us-east-1",
    "deploy": "npm run deploy:site && npm run deploy:lambda"
  },
  "dependencies": {
    "@remotion/transitions": "4.0.290",
    "remotion": "4.0.290",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@remotion/lambda": "4.0.290",
    "@remotion/cli": "4.0.290",
    "@types/react": "18.2.0",
    "typescript": "5.3.3"
  }
}
